{
  "name": "auriga",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Auriga — a harness job platform for agents (agent-flavored job scheduler / control plane).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "test": "bun test packages apps/api scripts",
    "check": "bun run typecheck && bun run lint && bun run test",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@types/bun": "^1.2.0",
    "@types/pg": "^8.20.0",
    "graphile-worker": "^0.17.2",
    "lefthook": "^2.1.9",
    "pg": "^8.21.0",
    "typescript": "^5.7.0"
  }
}

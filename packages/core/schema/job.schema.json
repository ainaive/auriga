{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "factio": {
      "type": "string",
      "minLength": 1
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "context_refs": {
      "type": "object",
      "properties": {
        "workspace": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "git",
                "dir"
              ]
            },
            "url_or_path": {
              "type": "string",
              "minLength": 1
            },
            "ref": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "url_or_path"
          ],
          "additionalProperties": false
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "workspace"
      ],
      "additionalProperties": false
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "minItems": 1,
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "command"
              },
              "cmd": {
                "type": "string",
                "minLength": 1
              },
              "expect_exit": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "kind",
              "cmd",
              "expect_exit"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "file_exists"
              },
              "path": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kind",
              "path"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "named_check"
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kind",
              "name"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "budget": {
      "type": "object",
      "properties": {
        "max_tokens": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "max_wall_time_s": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "max_cost_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_steps": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "max_tokens",
        "max_wall_time_s",
        "max_cost_usd",
        "max_steps"
      ],
      "additionalProperties": false
    },
    "require_approval": {
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "factio",
    "created_by",
    "goal",
    "context_refs",
    "allowed_tools",
    "acceptance_criteria",
    "budget"
  ],
  "additionalProperties": false
}
